{
  "name": "@bridgarr/youtube",
  "version": "0.1.0",
  "description": "Search YouTube from Sonarr/Radarr for obscure broadcast TV & movies — Newznab indexer + SABnzbd emulation + yt-dlp downloads",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "express": "5.2.1",
    "multer": "2.1.1",
    "pino": "10.3.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/express": "5.0.6",
    "@types/multer": "2.1.0",
    "@types/node": "25.9.2",
    "@types/supertest": "7.2.0",
    "eslint": "10.4.1",
    "pino-pretty": "13.1.3",
    "supertest": "7.2.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.8"
  }
}
